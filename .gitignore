# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Results (large files)
data/results/*.json

# Temporary files
*.tmp
*.log

# Local-only metrics backups written by src/reevaluate.py
*.json.bak

# Office lock files (Word/Excel "~$..." while a doc is open)
~$*

# Local secrets — .env holds ANTHROPIC_API_KEY etc. NEVER commit.
# .env.example IS tracked as a non-secret template.
.env
.env.*
!.env.example

# macOS
.DS_Store
